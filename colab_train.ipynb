   "source": [
    "# 🦷 Dental AI — Tooth Position Predictor Training\n",
    "### Tooth-Aware Self-Supervised PointNet on Mandible Scans\n",
    "\n",
    "**Steps:**\n",
    "1. Clone repo & install dependencies\n",
    "2. Upload your mandible PLY files\n",
    "3. Run training (GPU)\n",
    "4. Download trained weights → upload to VPS"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "setup"
   },
   "source": [
    "# ── Step 1: Clone repo and install deps ─────────────────────────────────────\n",
    "!git clone https://github.com/cjbast248/Adlanding-new.git dental_ai\n",
    "%cd dental_ai\n",
    "!git pull\n",
    "\n",
    "# Install Open3D (for mesh loading) — quiet install\n",
    "!pip install open3d trimesh torch torchvision -q\n",
    "\n",
    "print('✅ Setup complete!')"
   ],
   "execution_count": None,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "upload_data"
   },
   "source": [
    "# ── Step 2: Upload jaw scan files ───────────────────────────────────────────\n",
    "import os\n",
    "from google.colab import files\n",
    "\n",
    "os.makedirs('jaw_scans', exist_ok=True)\n",
    "\n",
    "print('📂 Select ALL your mandible PLY/STL files (hold Ctrl for multiple):')\n",
    "uploaded = files.upload()\n",
    "\n",
    "# Move uploaded files to jaw_scans/\n",
    "for fname, data in uploaded.items():\n",
    "    dest = f'jaw_scans/{fname}'\n",
    "    with open(dest, 'wb') as f:\n",
    "        f.write(data)\n",
    "\n",
    "scans = [f for f in os.listdir('jaw_scans') if f.endswith(('.ply','.stl'))]\n",
    "print(f'\\n✅ Uploaded {len(scans)} scan files:')\n",
    "for s in scans:\n",
    "    print(f'  · {s}')"
   ],
   "execution_count": None,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "verify_gpu"
   },
   "source": [
    "# ── Step 3: Verify GPU ───────────────────────────────────────────────────────\n",
    "import torch\n",
    "print(f'PyTorch: {torch.__version__}')\n",
    "print(f'GPU available: {torch.cuda.is_available()}')\n",
    "if torch.cuda.is_available():\n",
    "    print(f'GPU: {torch.cuda.get_device_name(0)}')\n",
    "    print(f'Memory: {torch.cuda.get_device_properties(0).total_memory / 1e9:.1f} GB')"
   ],
   "execution_count": None,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "test_dataset"
   },
   "source": [
    "# ── Step 4: Test dataset (preview tooth detection) ──────────────────────────\n",
    "import sys\n",
    "sys.path.insert(0, 'dental_ai_poc/ml')\n",
    "\n",
    "# Patch import paths\n",
    "import importlib.util, os\n",
    "\n",
    "ml_dir = 'dental_ai_poc/ml'\n",
    "sys.path.insert(0, ml_dir)\n",
    "\n",
    "from dataset import DentalJawDataset\n",
    "\n",
    "print('🔍 Scanning jaw files and detecting teeth...')\n",
    "ds = DentalJawDataset(data_dir='jaw_scans', num_points=2048, train=True)\n",
    "print(f'\\n📊 Dataset ready: {len(ds)} training samples')\n",
    "\n",
    "# Show a sample\n",
    "pts, tgt = ds[0]\n",
    "print(f'Input shape: {pts.shape}  →  Target: {tgt[:3].numpy().round(1)} mm')"
   ],
   "execution_count": None,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "train"
   },
   "source": [
    "# ── Step 5: TRAINING ─────────────────────────────────────────────────────────\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import DataLoader\n",
    "import os, time\n",
    "\n",
    "sys.path.insert(0, 'dental_ai_poc/ml')\n",
    "from model import PointNetRegressor\n",
    "from dataset import DentalJawDataset\n",
    "\n",
    "# ── Config ──────────────────────────────────────────────────────────────────\n",
    "EPOCHS     = 200\n",
    "BATCH_SIZE = 16\n",
    "LR         = 5e-4\n",
    "NUM_POINTS = 2048\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f'Training on: {device}')\n",
    "\n",
    "# ── Dataset & Loader ────────────────────────────────────────────────────────\n",
    "dataset    = DentalJawDataset('jaw_scans', num_points=NUM_POINTS, train=True)\n",
    "dataloader = DataLoader(dataset, batch_size=BATCH_SIZE, shuffle=True,\n",
    "                        num_workers=2, drop_last=True)\n",
    "\n",
    "# ── Model ───────────────────────────────────────────────────────────────────\n",
    "model     = PointNetRegressor(output_dim=7).to(device)\n",
    "optimizer = optim.AdamW(model.parameters(), lr=LR, weight_decay=1e-4)\n",
    "scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=EPOCHS, eta_min=1e-5)\n",
    "criterion = nn.MSELoss()\n",
    "\n",
    "os.makedirs('checkpoints', exist_ok=True)\n",
    "best_loss = float('inf')\n",
    "\n",
    "print(f'\\n🚀 Training {EPOCHS} epochs on {len(dataset)} samples...\\n')\n",
    "print(f'{\"Epoch\":>6} | {\"MSE Loss\":>10} | {\"Pos Error (mm)\":>15} | {\"LR\":>8}')\n",
    "print('-' * 50)\n",
    "\n",
    "t0 = time.time()\n",
    "for epoch in range(EPOCHS):\n",
    "    model.train()\n",
    "    epoch_loss = 0.0\n",
    "    pos_errors = []\n",
    "\n",
    "    for pts, tgt in dataloader:\n",
    "        pts, tgt = pts.to(device), tgt.to(device)\n",
    "        optimizer.zero_grad()\n",
    "        out  = model(pts)\n",
    "        loss = criterion(out, tgt)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        epoch_loss += loss.item()\n",
    "\n",
    "        # Track position error in mm\n",
    "        with torch.no_grad():\n",
    "            pos_err = torch.norm(out[:, :3] - tgt[:, :3], dim=1).mean().item()\n",
    "            pos_errors.append(pos_err)\n",
    "\n",
    "    scheduler.step()\n",
    "    avg_loss = epoch_loss / len(dataloader)\n",
    "    avg_pos  = sum(pos_errors) / len(pos_errors)\n",
    "    current_lr = scheduler.get_last_lr()[0]\n",
    "\n",
    "    if (epoch + 1) % 10 == 0:\n",
    "        print(f'{epoch+1:>6} | {avg_loss:>10.5f} | {avg_pos:>15.2f} | {current_lr:>8.6f}')\n",
    "\n",
    "    # Save best model\n",
    "    if avg_loss < best_loss:\n",
    "        best_loss = avg_loss\n",
    "        torch.save(model.state_dict(), 'checkpoints/pointnet_best.pth')\n",
    "\n",
    "# Final save\n",
    "torch.save(model.state_dict(), 'checkpoints/pointnet_final.pth')\n",
    "elapsed = (time.time() - t0) / 60\n",
    "print(f'\\n✅ Training complete in {elapsed:.1f} min')\n",
    "print(f'Best loss: {best_loss:.5f}')\n",
    "print(f'Saved → checkpoints/pointnet_final.pth')"
   ],
   "execution_count": None,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "download"
   },
   "source": [
    "# ── Step 6: Download trained weights ────────────────────────────────────────\n",
    "from google.colab import files\n",
    "import shutil\n",
    "\n",
    "# Package both checkpoints\n",
    "shutil.copy('checkpoints/pointnet_final.pth', '/content/pointnet_final.pth')\n",
    "files.download('/content/pointnet_final.pth')\n",
    "\n",
    "print('\\n📦 Downloaded pointnet_final.pth')\n",
    "print('\\n🔧 To upload to VPS, run:')\n",
    "print('scp pointnet_final.pth root@192.248.145.64:/opt/dental_ai_poc/checkpoints/')\n",
    "print('ssh root@192.248.145.64 \"systemctl restart dental_ai\"')"
   ],
   "execution_count": None,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "eval"
   },
   "source": [
    "# ── Optional: Quick evaluation on one scan ──────────────────────────────────\n",
    "import open3d as o3d\n",
    "import numpy as np\n",
    "import os\n",
    "\n",
    "model.eval()\n",
    "test_files = [f for f in os.listdir('jaw_scans') if f.endswith('.ply')]\n",
    "\n",
    "if test_files:\n",
    "    test_file = f'jaw_scans/{test_files[0]}'\n",
    "    mesh = o3d.io.read_triangle_mesh(test_file)\n",
    "    pcd  = mesh.sample_points_uniformly(number_of_points=2048)\n",
    "    pts  = np.asarray(pcd.points, dtype=np.float32)\n",
    "    cen  = np.mean(pts, axis=0)\n",
    "    pts -= cen\n",
    "\n",
    "    t = torch.tensor(pts, dtype=torch.float32).unsqueeze(0).to(device)\n",
    "    with torch.no_grad():\n",
    "        out = model(t).cpu().numpy()[0]\n",
    "\n",
    "    pred_pos = out[:3] + cen\n",
    "    print(f'Test scan: {test_files[0]}')\n",
    "    print(f'Predicted tooth position: {pred_pos.round(2)} mm')\n",
    "    print(f'\\n(Jaw center: {cen.round(2)})')\n",
    "else:\n",
    "    print('No PLY files found for evaluation.')"
   ],
   "execution_count": None,
   "outputs": []
  }
 ]
}
